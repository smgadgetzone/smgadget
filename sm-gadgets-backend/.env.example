# =====================================================
# SM Gadgets Backend - Environment Variables Template
# =====================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git. This file is safe to commit.

# --- Database ---
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# --- Server ---
PORT=5000

# --- Authentication ---
JWT_SECRET=your_super_secret_jwt_key_here

# --- Email (Nodemailer / Gmail) ---
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# --- Razorpay Payment Gateway ---
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# --- Shiprocket Logistics ---
# Your Shiprocket account login credentials
SHIPROCKET_EMAIL=your_shiprocket_login_email@gmail.com
SHIPROCKET_PASSWORD=your_shiprocket_password_here

# Default shipping dimensions (used as fallback if product has no dimensions set)
# These are also overridden per-product once you fill in dimensions in Admin Panel
SHIPROCKET_DEFAULT_WEIGHT=0.5     # kg
SHIPROCKET_DEFAULT_LENGTH=10      # cm
SHIPROCKET_DEFAULT_WIDTH=10       # cm
SHIPROCKET_DEFAULT_HEIGHT=5       # cm
